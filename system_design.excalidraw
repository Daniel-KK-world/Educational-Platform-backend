    {
      "id": "NYJGxerGfWZ32IpWQCXYv",
      "type": "text",
      "x": -371.8450580261291,
      "y": -1166.1330417131767,
      "width": 603.6213556880127,
      "height": 1400,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
